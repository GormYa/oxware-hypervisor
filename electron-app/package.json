{
  "name": "oxware-desktop",
  "version": "2.7.0",
  "description": "OXware Hypervisor Desktop Client",
  "main": "main.js",
  "author": "OXware",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "top.oxware.desktop",
    "productName": "OXware",
    "copyright": "Copyright © 2026 OXware",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ShinnAsukha",
        "repo": "oxware-hypervisor"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icons/icon.icns",
      "hardenedRuntime": false,
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "linux": {
      "icon": "build/icons",
      "category": "Utility",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OXware"
    },
    "dmg": {
      "title": "OXware ${version}",
      "background": null
    }
  }
}
